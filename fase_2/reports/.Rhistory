main = "TMB por sexo")
sample_means <- colMeans(expr_mat, na.rm = TRUE)
sample_medians <- apply(expr_mat, 2, median, na.rm = TRUE)
sample_sds <- apply(expr_mat, 2, sd, na.rm = TRUE)
