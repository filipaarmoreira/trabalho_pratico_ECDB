ic= prop.test(x, n, conf.level = 0.99, correct = FALSE)
cat("Proporção amostral:", round(prop, 4), "\n")
print(ic)
ep= sqrt(p_chapeu * (1 - p_chapeu) / n)
n= 500
x= 37
confianca= 0.99
p_chapeu= x / n
ep= sqrt(p_chapeu * (1 - p_chapeu) / n)
z= qnorm(1 - 0.01/2)
margem_erro= z * ep
limite_inf= p_chapeu - margem_erro
limite_sup= p_chapeu + margem_erro
cat("Valor Z crítico:", round(z, 4), "\n")
cat("Erro Padrão:", round(ep, 4), "\n")
cat("Margem de Erro:", round(margem_erro, 4), "\n\n")
cat("Intervalo de Confiança de 99%:\n")
cat("  [", round(limite_inf, 4), ";", round(limite_sup, 4), "]\n")
cat("  [", round(limite_inf * 100, 2), "%;",
round(limite_sup * 100, 2), "%]\n")
