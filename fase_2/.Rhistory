head(colnames(dados_clinicos), 10)
# 1. Voltar a carregar os ficheiros para a memória do R
dados_clinicos <- read.delim("luad_tcga_pan_can_atlas_2018_clinical_data.tsv", sep = "\t", header = TRUE)
dados_expressao <- read.delim("data_mrna_seq_v2_rsem.txt", sep = "\t", header = TRUE)
# 2. Ver os nomes das primeiras colunas dos dados clínicos
head(colnames(dados_clinicos), 10)
# 3. Ver os nomes das primeiras colunas dos dados de expressão
head(colnames(dados_expressao), 5)
merged <- merge(
data_clinical_sample,
expr,
by.x = "SAMPLE_ID",
by.y = "row.names"
)
# --- Substituir o código da Secção 3.2 por este ---
# 1. Uniformizar os nomes dos doentes (mudar hífens para pontos nos dados clínicos)
dados_clinicos$Sample.ID <- gsub("-", ".", dados_clinicos$Sample.ID)
# 2. Passar os nomes dos genes para o nome das linhas e apagar as duas primeiras colunas de texto
rownames(dados_expressao) <- dados_expressao$Hugo_Symbol
# 1. Uniformizar os nomes dos doentes
dados_clinicos$Sample.ID <- gsub("-", ".", dados_clinicos$Sample.ID)
# --- A SUA SOLUÇÃO PARA O ERRO ---
# Remover linhas com genes duplicados e linhas sem nome de gene
dados_expressao <- dados_expressao[!duplicated(dados_expressao$Hugo_Symbol), ]
dados_expressao <- dados_expressao[dados_expressao$Hugo_Symbol != "", ]
# ---------------------------------
# 2. Passar os nomes dos genes para o nome das linhas e apagar as colunas 1 e 2
rownames(dados_expressao) <- dados_expressao$Hugo_Symbol
dados_expressao <- dados_expressao[, -c(1, 2)]
# 3. Descobrir os doentes em comum
amostras_comuns <- intersect(dados_clinicos$Sample.ID, colnames(dados_expressao))
# 4. Filtrar ambas as tabelas para manter SÓ os doentes em comum
clinica_final <- dados_clinicos[dados_clinicos$Sample.ID %in% amostras_comuns, ]
expressao_final <- dados_expressao[, amostras_comuns]
# 5. Passo CRÍTICO: Garantir que a ordem dos doentes é estritamente igual
rownames(clinica_final) <- clinica_final$Sample.ID
clinica_final <- clinica_final[colnames(expressao_final), ]
# Confirmar se as amostras estão perfeitamente alinhadas (deve dar TRUE)
all(rownames(clinica_final) == colnames(expressao_final))
id="qpxyva"
dim(merged)
# 1. Confirmar o número de amostras (pacientes) que sobreviveram à filtragem
