geom_histogram(aes(y = ..density..), binwidth = 5, fill = "#3498db", color = "white", alpha = 0.8) +
geom_density(color = "#e74c3c", size = 1) +
labs(title = "Distribuição da Saúde da Bateria (%)",
subtitle = "A linha vermelha representa a densidade estimada",
x = "Saúde da Bateria (%)",
y = "Densidade") +
theme_minimal()
