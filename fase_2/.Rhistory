# Converter variáveis qualitativas em Fatores (Categorias)
# Isto é OBRIGATÓRIO para a regressão funcionar bem
dados$brand <- as.factor(dados$brand)
dados$os <- as.factor(dados$os)
dados$overheating_issues <- as.factor(dados$overheating_issues)
dados$usage_type <- as.factor(dados$usage_type)
# Verificar se ficou tudo bem
str(dados)
head(dados)
