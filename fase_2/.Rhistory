valores= c(5260, 5470, 5640, 6180, 6390, 6515, 6805, 7515, 7515, 8230, 8770)
media= mean(valores)
mediana= median(valores)
amplitude= max(valores) - min(valores)
variancia= var(valores)
desvio_padrao= sd(valores)
quartis <- quantile(valores, probs = c(0.25, 0.5, 0.75))
cat("Média:", media, "\n")
cat("Mediana:", mediana, "\n")
cat("Amplitude:", amplitude, "\n")
cat("Variância:", variancia, "\n")
cat("Desvio padrão:", desvio_padrao, "\n")
cat("Quartis:\n"); print(quartis)
hist(valores, main = "Histograma do Valor Calórico Médio (kJ)", xlab = "Valor calórico (kJ)",col = "lightblue", border = "black")
boxplot(valores, horizontal = TRUE, main = "Gráfico de Caixa e Bigodes", xlab = "Valor calórico (kJ)", col = "lightgreen")
n= length(valores)
erro_padrao= desvio_padrao / sqrt(n)
t_critico= qt(0.975, df = n - 1)
ic_inferior= media - t_critico * erro_padrao
ic_superior= media + t_critico * erro_padrao
cat("Intervalo de confiança 95%: [", ic_inferior, ",", ic_superior, "]\n")
valor_recomendado= 7725
teste= t.test(valores, mu = valor_recomendado)
print(teste)
diferencas= valores - valor_recomendado
teste_diff= t.test(diferencas, mu = 0)
print(teste_diff)
